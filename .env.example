# --- Core ---
DATABASE_URL=sqlite:///./badger_cfo.db
TELEGRAM_BOT_TOKEN=

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Access code for the phone app / API. REQUIRED for any public deploy —
# without it anyone with the URL sees your finances. Leave empty only for
# local development.
APP_ACCESS_CODE=

# --- Plaid (read-only products ONLY) ---
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
PLAID_PRODUCTS=transactions,balance,liabilities,investments
PLAID_COUNTRY_CODES=US

# --- Market data ---
COINMARKETCAP_API_KEY=
COINGECKO_API_KEY=

# --- Exchanges (READ-ONLY API keys only; trade/withdraw keys are rejected) ---
COINBASE_API_KEY=
COINBASE_API_SECRET=

BYBIT_API_KEY=
BYBIT_API_SECRET=

BINANCE_API_KEY=
BINANCE_API_SECRET=

ROBINHOOD_MODE=manual

# --- News ---
NEWS_API_KEY=

# --- Reports ---
REPORT_TIMEZONE=America/New_York
MORNING_REPORT_TIME=08:00
EVENING_REPORT_TIME=21:00
