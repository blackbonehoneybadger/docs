# Скопируй этот файл в .env и при необходимости поменяй значения.
# cp .env.example .env

# Сеть: devnet (тест, бесплатно) или mainnet-beta (реальная сеть, реальные деньги).
CLUSTER=devnet

# (необязательно) свой RPC-узел. Если пусто — берётся публичный по CLUSTER.
RPC_URL=

# Файл с ключом владельца (массив чисел из 64 байт). Создаётся командой npm run keygen.
# НИКОМУ не показывай этот файл и сид-фразу. Это полный контроль над токеном.
KEYPAIR_PATH=./owner.json

# Параметры токена
TOKEN_NAME=DOFFA
TOKEN_SYMBOL=DOFFA
TOKEN_DECIMALS=6
TOKEN_SUPPLY=100000000

# Ссылка на JSON-метаданные токена (имя, символ, логотип) на Arweave/IPFS/Shadow Drive.
# Для теста можно временный URL; для mainnet — постоянное хранилище.
METADATA_URI=https://example.com/doffa-token.json

# Адрес минта. Заполняется автоматически после npm run create (файл .doffa-mint.json),
# но можно задать вручную здесь, чтобы burn/revoke/verify знали, с каким токеном работать.
MINT_ADDRESS=
