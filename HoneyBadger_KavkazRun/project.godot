; Engine configuration file.
; Honey Badger: Кавказский Забег
; Godot 4.3 project

config_version=5

[application]

config/name="Honey Badger: Кавказский Забег"
config/description="2D pixel-art platformer. World 1: Adygea."
run/main_scene="res://scenes/ui/MainMenu.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

GameManager="*res://scripts/globals/GameManager.gd"
CharacterConfig="*res://scripts/globals/CharacterConfig.gd"
AudioManager="*res://scripts/globals/AudioManager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation="landscape"

